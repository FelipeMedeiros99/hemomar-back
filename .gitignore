# Compiled output (Arquivos compilados)
/dist
/node_modules

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS Files (Arquivos do Sistema Operacional)
.DS_Store
Thumbs.db

# Tests (Cobertura de testes e temporários)
/coverage
/.nyc_output

# IDEs and Editors (Configurações de editores de código)
/.idea
.project
.classpath
.cproject
.settings
/.vscode
!.vscode/extensions.json
!.vscode/launch.json
.vscode/*.log

# Environment variables (Arquivos de configuração e senhas - MUITO IMPORTANTE)
.env
.env.development
.env.test
.env.production
.env.local
.env.*.local

# Nest CLI cache (Cache do próprio NestJS)
.nestcli.json

# Package manager locks (Opcional - Remova da lista se quiser salvar no Git)
# yarn.lock
# package-lock.json
# pnpm-lock.yaml

